    "drizzle-orm": "^0.41.0",
    "express": "^5.2.1",
    "express-openapi-validator": "^5.4.0",
    "luxon": "^3.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.6",
    "@types/luxon": "^3.4.0",
    "@types/supertest": "^6.0.0",
    "drizzle-kit": "^0.30.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^3.1.0"
  }
}
